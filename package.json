{
  "name": "flexflow-backend",
  "version": "1.0.0",
  "description": "FlexFlow API — Financial planning for the self-employed",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "setup": "npm install && npm run migrate && npm run seed",
    "config:update-rates": "node scripts/updateRates.js",
    "config:update-expenses": "node scripts/updateExpenses.js",
    "config:update-copy": "node scripts/updateCopy.js",
    "config:rollback": "node scripts/rollback.js",
    "test": "node --test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "stripe": "^16.2.0",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.15.0",
    "aws-sdk": "^2.1650.0",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "eslint": "^9.6.0",
    "prettier": "^3.3.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
